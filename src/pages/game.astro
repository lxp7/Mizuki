---
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import { siteConfig } from "../config";
import localGameList from "../data/game"; // 你的本地游戏数据（已包含 appid 或手动 cover）
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { widgetManager } from "../utils/widget-manager";
import "../styles/game.css";

// ---------- 类型定义 ----------
// 原始数据格式（从本地文件或 Steam API 读取）
interface RawGameItem {
  title?: string;
  appid?: number;           // Steam appid
  cover?: string;           // 手动指定的封面 URL
  link?: string;
  status?: string;          // playing, completed, planned, onhold, dropped
  rating?: number | string;
  progress?: number | string;
  achievements?: number | string;
  description?: string;
  releaseYear?: string;
  developer?: string;
  genre?: string[];
  platform?: string;
}

// 最终使用的游戏项（所有字段非空）
interface GameItem {
  title: string;
  appid?: number;
  cover: string;            // 保证有有效 URL
  link: string;
  status: string;
  rating: number;
  progress: number;
  achievements: number;
  description: string;
  releaseYear: string;
  developer: string;
  genre: string[];
  platform: string;
}

// ---------- 工具函数 ----------
// 生成 Steam 竖版封面 URL
function getSteamCoverUrl(appid: number): string {
  return `https://shared.st.dl.eccdnx.com/store_item_assets/steam/apps/${appid}/library_600x900.jpg`;
}

// 将原始数据转换为标准 GameItem（自动处理封面）
function normalizeGameItem(raw: RawGameItem): GameItem {
  let cover = raw.cover || '';
  if (!cover && raw.appid) {
    cover = getSteamCoverUrl(raw.appid);
  }
  if (!cover) {
    cover = '/images/default-game-cover.jpg'; // 确保有默认图
  }

  return {
    title: raw.title || '未知游戏',
    appid: raw.appid,
    cover,
    link: raw.link || '#',
    status: raw.status || 'planned',
    rating: typeof raw.rating === 'number' ? raw.rating : Number(raw.rating) || 0,
    progress: typeof raw.progress === 'number' ? raw.progress : Number(raw.progress) || 0,
    achievements: typeof raw.achievements === 'number' ? raw.achievements : Number(raw.achievements) || 0,
    description: raw.description || '',
    releaseYear: raw.releaseYear || '',
    developer: raw.developer || '',
    genre: raw.genre || [],
    platform: raw.platform || '',
  };
}

// ---------- 数据加载 ----------
// 本地数据（已经是 RawGameItem 数组，假设符合接口）
const rawGames: RawGameItem[] = localGameList;

// 转换为标准格式
let gameList: GameItem[] = rawGames.map(normalizeGameItem);

// 可选：如果以后需要合并 Steam API 数据，可以在这里添加
// 例如：
// import steamData from '../data/steam-data.json';
// const steamRawGames = steamData.map(...);
// gameList = [...gameList, ...steamRawGames.map(normalizeGameItem)];

// 计算右侧边栏（用于布局）
const hasRightSidebars =
  widgetManager.getComponentsByPosition("top", "right", "desktop").length > 0 ||
  widgetManager.getComponentsByPosition("sticky", "right", "desktop").length > 0;

// 空状态处理
let emptyMessage = i18n(I18nKey.gamesEmpty);
let emptyDescription = "";
let showEmptyState = gameList.length === 0;
if (showEmptyState) {
  emptyDescription = i18n(I18nKey.gamesEmptyLocal);
}

// 状态样式映射
const statusMap: Record<string, { text: string; class: string; icon: string }> = {
  playing: {
    text: i18n(I18nKey.gameStatusPlaying),
    class: "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300",
    icon: "▶",
  },
  completed: {
    text: i18n(I18nKey.gameStatusCompleted),
    class: "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300",
    icon: "✓",
  },
  planned: {
    text: i18n(I18nKey.gameStatusPlanned),
    class: "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300",
    icon: "❤",
  },
  onhold: {
    text: i18n(I18nKey.gameStatusOnHold),
    class: "bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300",
    icon: "⏸",
  },
  dropped: {
    text: i18n(I18nKey.gameStatusDropped),
    class: "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300",
    icon: "✗",
  },
};

function getStatusInfo(status: string) {
  return statusMap[status] || {
    text: status,
    class: "bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300",
    icon: "?",
  };
}

const INITIAL_DISPLAY_COUNT = 24;
const visibleGameList = gameList.slice(0, INITIAL_DISPLAY_COUNT);
const hiddenGameList = gameList.slice(INITIAL_DISPLAY_COUNT);
---

<MainGridLayout title={i18n(I18nKey.games)} description={i18n(I18nKey.gamesSubtitle)}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base game-card-base z-10 px-9 py-6 relative w-full">
      <div class="relative w-full mb-8">
        <div class="mb-6">
          <h1
            class="text-4xl font-bold text-90 mb-2 relative
              before:w-1 before:h-8 before:rounded-md before:bg-(--primary)
              before:absolute before:top-1/2 before:-translate-y-1/2 before:-left-4"
          >
            {i18n(I18nKey.gamesTitle)}
          </h1>
          <p class="text-75">{i18n(I18nKey.gamesSubtitle)}</p>
        </div>

        <div class="mb-6">
          <div class="game-filter-container flex flex-wrap gap-2">
            <button class="game-filter-tag game-active" data-status="all">
              {i18n(I18nKey.gamesFilterAll)}
            </button>
            <button class="game-filter-tag" data-status="playing">
              {i18n(I18nKey.gameStatusPlaying)}
            </button>
            <button class="game-filter-tag" data-status="planned">
              {i18n(I18nKey.gameStatusPlanned)}
            </button>
            <button class="game-filter-tag" data-status="completed">
              {i18n(I18nKey.gameStatusCompleted)}
            </button>
            <button class="game-filter-tag" data-status="onhold">
              {i18n(I18nKey.gameStatusOnHold)}
            </button>
            <button class="game-filter-tag" data-status="dropped">
              {i18n(I18nKey.gameStatusDropped)}
            </button>
          </div>
        </div>
      </div>

      <div class="mb-8">
        {showEmptyState ? (
          <div class="text-center py-12">
            <div class="text-5xl mb-4">😢</div>
            <h3 class="text-xl font-medium text-90 mb-2">{emptyMessage}</h3>
            <p class="text-60">{emptyDescription}</p>
          </div>
        ) : (
          <>
            <div
              id="game-list-container"
              class="game-grid-container grid gap-4 md:gap-6 grid-cols-1 lg:grid-cols-2"
            >
              {visibleGameList.map((game) => {
                const statusInfo = getStatusInfo(game.status);
                const progressPercent =
                  game.achievements > 0 ? (game.progress / game.achievements) * 100 : 0;

                return (
                  <div
                    class="group relative bg-(--card-bg) border border-(--line-divider) rounded-(--radius-large) overflow-hidden hover:shadow-lg"
                    data-game-status={game.status}
                  >
                    <div class="relative game-cover-container aspect-2/3 overflow-hidden">
                      <a
                        href={game.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="block w-full h-full"
                      >
                        <ImageWrapper
                          src={game.cover}
                          alt={game.title}
                          class="w-full h-full object-cover transition-transform duration-200 group-hover:scale-110"
                        />
                        <div class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                          <div class="absolute inset-0 flex items-center justify-center">
                            <div class="w-12 h-12 rounded-full bg-white/90 flex items-center justify-center">
                              <svg
                                class="w-6 h-6 text-gray-800 ml-1"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                              >
                                <path d="M8 5v14l11-7z" />
                              </svg>
                            </div>
                          </div>
                        </div>
                      </a>

                      <div
                        class={`absolute top-2 left-2 px-2 py-1 rounded-md text-xs font-medium ${statusInfo.class}`}
                      >
                        <span class="mr-1">{statusInfo.icon}</span>
                        <span>{statusInfo.text}</span>
                      </div>

                      <div class="absolute top-2 right-2 bg-black/70 text-white px-2 py-1 rounded-md text-xs font-medium flex items-center gap-1">
                        <svg
                          class="w-3 h-3 text-yellow-400"
                          fill="currentColor"
                          viewBox="0 0 20 20"
                        >
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                        <span>{game.rating}</span>
                      </div>

                      {game.status === "playing" && (
                        <div class="absolute bottom-0 left-0 right-0 bg-linear-to-t from-black/80 to-transparent p-2">
                          <div class="w-full bg-white/20 rounded-full h-1.5 mb-1">
                            <div
                              class="bg-linear-to-r from-emerald-400 to-teal-400 h-1.5 rounded-full transition-all duration-300"
                              style={`width: ${progressPercent}%`}
                            />
                          </div>
                          <div class="text-white text-xs font-medium">
                            {game.progress}/{game.achievements} 成就 ({Math.round(progressPercent)}%)
                          </div>
                        </div>
                      )}
                    </div>

                    <div class="p-3">
                      <h3 class="text-sm font-bold text-90 mb-1 leading-tight">{game.title}</h3>
                      <p class="text-60 text-xs mb-2 line-clamp-2" title={game.description}>
                        {game.description}
                      </p>

                      <div class="space-y-1 text-xs">
                        <div class="flex justify-between items-center">
                          <span class="text-50 shrink-0">{i18n(I18nKey.gamePlatform)}</span>
                          <span class="text-70 truncate ml-2 text-right">{game.platform}</span>
                        </div>
                        <div class="flex justify-between items-center">
                          <span class="text-50 shrink-0">{i18n(I18nKey.gameReleaseYear)}</span>
                          <span class="text-70 truncate ml-2 text-right">{game.releaseYear}</span>
                        </div>
                        <div class="flex justify-between items-start">
                          <span class="text-50 shrink-0 mt-0.5">{i18n(I18nKey.gameDeveloper)}</span>
                          <span class="text-70 text-right ml-2 line-clamp-2 wrap-break-word" title={game.developer}>
                            {game.developer}
                          </span>
                        </div>
                        <div class="flex flex-wrap gap-1 mt-2">
                          {game.genre.map((g) => (
                            <span class="px-1.5 py-0.5 bg-(--btn-regular-bg) text-70 rounded text-xs">
                              {g}
                            </span>
                          ))}
                        </div>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>

            <template id="game-lazy-store">
              {hiddenGameList.map((game) => {
                const statusInfo = getStatusInfo(game.status);
                const progressPercent =
                  game.achievements > 0 ? (game.progress / game.achievements) * 100 : 0;

                return (
                  <div
                    class="group relative bg-(--card-bg) border border-(--line-divider) rounded-(--radius-large) overflow-hidden hover:shadow-lg"
                    data-game-status={game.status}
                  >
                    {/* 卡片内容与上面一致 */}
                    <div class="relative game-cover-container aspect-2/3 overflow-hidden">
                      <a
                        href={game.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="block w-full h-full"
                      >
                        <ImageWrapper
                          src={game.cover}
                          alt={game.title}
                          class="w-full h-full object-cover transition-transform duration-200 group-hover:scale-110"
                        />
                        <div class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                          <div class="absolute inset-0 flex items-center justify-center">
                            <div class="w-12 h-12 rounded-full bg-white/90 flex items-center justify-center">
                              <svg class="w-6 h-6 text-gray-800 ml-1" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M8 5v14l11-7z" />
                              </svg>
                            </div>
                          </div>
                        </div>
                      </a>

                      <div class={`absolute top-2 left-2 px-2 py-1 rounded-md text-xs font-medium ${statusInfo.class}`}>
                        <span class="mr-1">{statusInfo.icon}</span>
                        <span>{statusInfo.text}</span>
                      </div>

                      <div class="absolute top-2 right-2 bg-black/70 text-white px-2 py-1 rounded-md text-xs font-medium flex items-center gap-1">
                        <svg class="w-3 h-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                        <span>{game.rating}</span>
                      </div>

                      {game.status === "playing" && (
                        <div class="absolute bottom-0 left-0 right-0 bg-linear-to-t from-black/80 to-transparent p-2">
                          <div class="w-full bg-white/20 rounded-full h-1.5 mb-1">
                            <div
                              class="bg-linear-to-r from-emerald-400 to-teal-400 h-1.5 rounded-full transition-all duration-300"
                              style={`width: ${progressPercent}%`}
                            />
                          </div>
                          <div class="text-white text-xs font-medium">
                            {game.progress}/{game.achievements} 成就 ({Math.round(progressPercent)}%)
                          </div>
                        </div>
                      )}
                    </div>

                    <div class="p-3">
                      <h3 class="text-sm font-bold text-90 mb-1 leading-tight">{game.title}</h3>
                      <p class="text-60 text-xs mb-2 line-clamp-2" title={game.description}>
                        {game.description}
                      </p>

                      <div class="space-y-1 text-xs">
                        <div class="flex justify-between items-center">
                          <span class="text-50 shrink-0">{i18n(I18nKey.gamePlatform)}</span>
                          <span class="text-70 truncate ml-2 text-right">{game.platform}</span>
                        </div>
                        <div class="flex justify-between items-center">
                          <span class="text-50 shrink-0">{i18n(I18nKey.gameReleaseYear)}</span>
                          <span class="text-70 truncate ml-2 text-right">{game.releaseYear}</span>
                        </div>
                        <div class="flex justify-between items-start">
                          <span class="text-50 shrink-0 mt-0.5">{i18n(I18nKey.gameDeveloper)}</span>
                          <span class="text-70 text-right ml-2 line-clamp-2 wrap-break-word" title={game.developer}>
                            {game.developer}
                          </span>
                        </div>
                        <div class="flex flex-wrap gap-1 mt-2">
                          {game.genre.map((g) => (
                            <span class="px-1.5 py-0.5 bg-(--btn-regular-bg) text-70 rounded text-xs">
                              {g}
                            </span>
                          ))}
                        </div>
                      </div>
                    </div>
                  </div>
                );
              })}
            </template>

            {hiddenGameList.length > 0 && (
              <div id="infinite-scroll-sentinel" class="w-full h-20 flex items-center justify-center mt-8">
                <div class="game-loading-spinner w-8 h-8 border-4 border-(--primary) border-t-transparent rounded-full animate-spin" />
              </div>
            )}
          </>
        )}
      </div>
    </div>
  </div>

  <script is:inline>
    (function() {
      function initFilterButtons() {
        const filterTags = document.querySelectorAll(".game-filter-tag");
        const sentinel = document.getElementById("infinite-scroll-sentinel");
        const listContainer = document.getElementById("game-list-container");
        const lazyStore = document.getElementById("game-lazy-store");

        if (!filterTags.length || !listContainer) return;

        filterTags.forEach(tag => {
          tag.addEventListener("click", function() {
            if (this.classList.contains("game-active")) return;

            filterTags.forEach(t => t.classList.remove("game-active"));
            this.classList.add("game-active");

            if (lazyStore && lazyStore.content.children.length > 0 && listContainer) {
              const fragment = document.createDocumentFragment();
              while (lazyStore.content.firstChild) {
                fragment.appendChild(lazyStore.content.firstChild);
              }
              listContainer.appendChild(fragment);
            }

            if (sentinel) sentinel.style.display = "none";

            const status = this.getAttribute("data-status");
            const gameItems = Array.from(listContainer.children).filter(
              item => item.hasAttribute("data-game-status")
            );

            gameItems.forEach(item => {
              const itemStatus = item.getAttribute("data-game-status");
              const shouldShow = status === "all" || itemStatus === status;
              item.style.display = shouldShow ? "block" : "none";
            });
          });
        });

        if (sentinel && lazyStore && listContainer) {
          const observer = new IntersectionObserver(
            (entries) => {
              if (entries[0].isIntersecting) {
                const BATCH_SIZE = 24;
                if (lazyStore.content.children.length === 0) {
                  sentinel.style.display = "none";
                  observer.disconnect();
                  return;
                }

                const fragment = document.createDocumentFragment();
                let movedCount = 0;
                while (lazyStore.content.firstChild && movedCount < BATCH_SIZE) {
                  fragment.appendChild(lazyStore.content.firstChild);
                  movedCount++;
                }

                requestAnimationFrame(() => {
                  listContainer.appendChild(fragment);
                  if (lazyStore.content.children.length === 0) {
                    sentinel.style.display = "none";
                    observer.disconnect();
                  }
                });
              }
            },
            { rootMargin: "200px" }
          );
          observer.observe(sentinel);
        } else if (sentinel) {
          sentinel.style.display = "none";
        }
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initFilterButtons);
      } else {
        initFilterButtons();
      }

      if (window.swup) {
        window.swup.hooks.on("content:replace", () => setTimeout(initFilterButtons, 150));
      } else {
        document.addEventListener("swup:enable", () => {
          window.swup.hooks.on("content:replace", () => setTimeout(initFilterButtons, 150));
        });
      }
    })();
  </script>
</MainGridLayout>